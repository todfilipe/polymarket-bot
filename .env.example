# ============================================================
# Polymarket Copytrade Bot — variáveis de ambiente
# Copia este ficheiro para .env e preenche com os teus valores
# NUNCA commitar .env ao git
# ============================================================

# --- MODO DE OPERAÇÃO ---
# false (default) = dry-run / paper trading. Loga decisões sem enviar ordens.
# true = live trading com dinheiro real. Só ligar após ≥ 2 semanas de paper.
LIVE_MODE=false

# --- POLYGON / POLYMARKET ---
# Private key da wallet Polygon (sem prefixo 0x)
POLYGON_PRIVATE_KEY=

# Chain ID: 137 = Polygon mainnet, 80002 = Polygon Amoy (testnet)
POLYGON_CHAIN_ID=137

# RPC Polygon (Alchemy/Infura/public). Usado como fallback para histórico on-chain.
POLYGON_RPC_URL=https://polygon-rpc.com

# CLOB host oficial
CLOB_API_URL=https://clob.polymarket.com

# Data API (histórico de trades por wallet)
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com

# Gamma API (metadata de mercados)
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com

# Credenciais CLOB: deixar em branco na primeira execução.
# O bot gera-as automaticamente a partir da POLYGON_PRIVATE_KEY no setup e imprime.
# Depois copia-as para cá para evitar regeneração.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Endereço do proxy wallet (preenchido após a primeira execução).
PROXY_WALLET_ADDRESS=

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- PERSISTÊNCIA ---
DATABASE_URL=sqlite+aiosqlite:///./data/polymarket_bot.db

# --- LOGGING ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- UNIVERSO DE WALLETS ---
# Top-N wallets candidatas a avaliar no scoring de domingo
WALLET_DISCOVERY_TOP_N=150

# Janela de análise (semanas) para scoring
SCORING_WINDOW_WEEKS=4
